package accessnyc.rules;

import accessnyc.response.EligibleProgram

import accessnyc.request.Person
import accessnyc.request.Household
import accessnyc.rules.income.IncomeHouseholdHasBenefit
import accessnyc.rules.income.IncomeHouseholdTotalYearly

rule "s2_r043.1"
    dialect "mvel"
    
    when
        (
            (Person( benefitsMedicaid == true ))
            or (Person( benefitsMedicaidDisability == true ))
        )
    then
        $programcode = new EligibleProgram()    
        $programcode.setCode("S2R043")
        insertLogical($programcode)  
end

rule "s2_r043.2"
    dialect "mvel"
    
    when
        IncomeHouseholdHasBenefit( value == true )
    then
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R043")
        insertLogical($programcode)   
    
end

rule "s2_r043.3"
    dialect "mvel"
    
    when
        Household( livingRenting == true, livingRentalType == "NYCHA")
    then
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R043")
        insertLogical($programcode)   
    
end

rule "s2_r043.4"
    dialect "mvel"
    
    when 
        (
            (Household(members == 1) and IncomeHouseholdTotalYearly( amount <= 21128 )) 
            or (Household(members == 2) and IncomeHouseholdTotalYearly( amount <= 28553 )) 
            or (Household(members == 3) and IncomeHouseholdTotalYearly( amount <= 35978 ))
            or (Household(members == 4) and IncomeHouseholdTotalYearly( amount <= 43403 ))
            or (Household(members == 5) and IncomeHouseholdTotalYearly( amount <= 50828 ))
            or (Household(members == 6) and IncomeHouseholdTotalYearly( amount <= 58253 ))
            or (Household(members == 7) and IncomeHouseholdTotalYearly( amount <= 65678 ))
            or (Household(members == 8) and IncomeHouseholdTotalYearly( amount <= 73103 ))
        )

    then
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R043")
        insertLogical($programcode)

end