package accessnyc.rules;

import accessnyc.response.EligibleProgram

import accessnyc.request.Person
import accessnyc.request.Household

import accessnyc.rules.income.IncomeHouseholdWageSelfEmploymentBoarderMonthly
import accessnyc.rules.snap.IncomeHouseholdAllSSIOrCash
import accessnyc.rules.snap.IncomeHouseholdMinusChildSupportPaid
import accessnyc.rules.expense.ExpenseHouseholdHasChildOrDependentCare
import accessnyc.rules.snap.IncomeSNAP

rule "s2_r007.2"
    dialect "mvel"
    
    when
        IncomeHouseholdAllSSIOrCash(value == true)  

    then
    
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R007")
        $programcode.setRulePart("2")
        insertLogical($programcode)
end


rule "s2_r007 200% of poverty level gross income: child care, dependent care, elderly person, disability, or blind"
    dialect "mvel"
    when
        ( 
            ExpenseHouseholdHasChildOrDependentCare(value == true) or
            Person( age >= 60 ) or
            Person(disabled == true) or
            Person( blind == true)
        )
        (
               (Household(members == 1) and IncomeHouseholdMinusChildSupportPaid(amount <= 2608))
            or (Household(members == 2) and IncomeHouseholdMinusChildSupportPaid(amount <= 3525))
            or (Household(members == 3) and IncomeHouseholdMinusChildSupportPaid(amount <= 4442))
            or (Household(members == 4) and IncomeHouseholdMinusChildSupportPaid(amount <= 5358))
            or (Household(members == 5) and IncomeHouseholdMinusChildSupportPaid(amount <= 6275))
            or (Household(members == 6) and IncomeHouseholdMinusChildSupportPaid(amount <= 7192))
            or (Household(members == 7) and IncomeHouseholdMinusChildSupportPaid(amount <= 8108))
            or (Household(members == 8) and IncomeHouseholdMinusChildSupportPaid(amount <= 9025))
        )
            
    then
    
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R007")
        insertLogical($programcode)
end

rule "s2_r007 150% of poverty level gross income: has earned income"
    dialect "mvel"
    
    when
        IncomeHouseholdWageSelfEmploymentBoarderMonthly(amount > 0)
        (
               (Household(members == 1) and IncomeHouseholdMinusChildSupportPaid(amount <= 1957))
            or (Household(members == 2) and IncomeHouseholdMinusChildSupportPaid(amount <= 2644))
            or (Household(members == 3) and IncomeHouseholdMinusChildSupportPaid(amount <= 3332))
            or (Household(members == 4) and IncomeHouseholdMinusChildSupportPaid(amount <= 4019))
            or (Household(members == 5) and IncomeHouseholdMinusChildSupportPaid(amount <= 4707))
            or (Household(members == 6) and IncomeHouseholdMinusChildSupportPaid(amount <= 5394))
            or (Household(members == 7) and IncomeHouseholdMinusChildSupportPaid(amount <= 6082))
            or (Household(members == 8) and IncomeHouseholdMinusChildSupportPaid(amount <= 6769))
        )
            
    then
    
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R007")
        insertLogical($programcode)
end

rule "s2_r007 130% of poverty level gross income: all other"
    dialect "mvel"
    
    when
       (
               (Household(members == 1) and IncomeHouseholdMinusChildSupportPaid(amount <= 1696))
            or (Household(members == 2) and IncomeHouseholdMinusChildSupportPaid(amount <= 2292))
            or (Household(members == 3) and IncomeHouseholdMinusChildSupportPaid(amount <= 2888))
            or (Household(members == 4) and IncomeHouseholdMinusChildSupportPaid(amount <= 3483))
            or (Household(members == 5) and IncomeHouseholdMinusChildSupportPaid(amount <= 4079))
            or (Household(members == 6) and IncomeHouseholdMinusChildSupportPaid(amount <= 4675))
            or (Household(members == 7) and IncomeHouseholdMinusChildSupportPaid(amount <= 5271))
            or (Household(members == 8) and IncomeHouseholdMinusChildSupportPaid(amount <= 5867))
        )
            
    then
    
        $programcode = new EligibleProgram()
        $programcode.setCode("S2R007")
        insertLogical($programcode)
end